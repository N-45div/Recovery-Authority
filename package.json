{
  "name": "recovery-authority",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun build ./src/cli.ts ./src/server.ts ./src/demo.ts ./src/mcp-proxy.ts ./src/sandbox.ts --outdir ./dist --target bun --minify-syntax --minify-whitespace",
    "approve": "bun run ./src/cli.ts approve",
    "sandbox": "bun run ./src/sandbox.ts sandbox",
    "demo": "bun ./dist/demo.js",
    "check": "tsc --noEmit",
    "dev": "bun run ./src/server.ts",
    "test": "bun test",
    "test:hook": "node ./scripts/smoke-hook.mjs",
    "test:mcp": "node ./scripts/smoke-mcp.mjs",
    "test:bundle": "node ./scripts/smoke-server-boundary.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "bash-parser": "^0.5.0",
    "pgsql-ast-parser": "^12.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  }
}
