{
  "name": "recovery-authority",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun build ./src/server.ts ./src/pre-tool-hook.ts ./src/approve.ts ./src/demo.ts --outdir ./dist --target bun",
    "approve": "bun run ./src/approve.ts approve",
    "demo": "bash ./scripts/demo-postgres.sh",
    "check": "tsc --noEmit",
    "dev": "bun run ./src/server.ts",
    "test": "bun test",
    "test:mcp": "node ./scripts/smoke-mcp.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "bash-parser": "^0.5.0",
    "pgsql-ast-parser": "^12.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  }
}
